pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                 git branch: 'main',
                url: 'https://github.com/madhurya25work-lab/GIR-DevSecOps.git'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t flask-trivy-app .'
            }
        }

        stage('Trivy Scan') {
            steps {
                sh '
                trivy image \
                --severity CRITICAL \
                --exit-code 1 \
                flask-trivy-app
                '
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'CRITICAL vulnerabilities found. Build failed.'
        }
    }
}