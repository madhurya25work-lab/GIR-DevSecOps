pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t flask-trivy-app .'
            }
        }

        stage('Trivy Scan') {
            steps {
                sh '''
                trivy image \
                --severity CRITICAL \
                --exit-code 1 \
                flask-trivy-app
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'CRITICAL vulnerabilities found. Build failed.'
        }
    }
}